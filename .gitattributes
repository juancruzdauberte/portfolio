# Normalizar todos los archivos de texto a LF en el repo
* text=auto eol=lf

# Archivos de texto explícitos
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env   text eol=lf

# Binarios — sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.pdf   binary
